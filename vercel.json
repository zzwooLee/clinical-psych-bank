{
  "rewrites": [
    {
      "source": "/api/admin/:action",
      "destination": "/api/admin.js?action=:action"
    },
    {
      "source": "/api/login",
      "destination": "/api/auth.js?action=login"
    },
    {
      "source": "/api/signup",
      "destination": "/api/auth.js?action=signup"
    },
    {
      "source": "/api/questions",
      "destination": "/api/questions.js"
    },
    {
      "source": "/api/years",
      "destination": "/api/years.js"
    },
    {
      "source": "/api/slack-action",
      "destination": "/api/slack-action.js"
    },
    {
      "source": "/api/send-mail",
      "destination": "/api/send-mail.js"
    }
  ]
}
